# PMO Frontend Environment Configuration
# Copy this file to .env. Required by docker-compose.yml (frontend.env_file).

# Browser-facing API origin. Because the app is a SPA (ssr: false), requests are made from the
# user's browser, so this must be reachable from the BROWSER, not container-to-container.
#
# - Local dev (npm run dev): LEAVE COMMENTED. Nuxt's Nitro devProxy (nuxt.config.ts) forwards
#   /api to the backend, avoiding CORS. Setting it here overrides the proxy.
# - Docker / production: docker-compose.yml overrides this per-container to
#   http://localhost:${BACKEND_PORT}. For a real deployment behind a domain, set it to the
#   public API URL, e.g. https://pmo.carsu.edu.ph/api
#
# NUXT_PUBLIC_API_BASE=http://localhost:3000
