# PMO Backend Environment Configuration
# Copy this file to .env and update values

# Database Connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=pmo_dashboard
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Alternative: Full connection string (overrides above if set)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/pmo_dashboard

# Application
PORT=3000
NODE_ENV=development

# Authentication (JWT)
AUTH_JWT_SECRET=your-super-secret-jwt-key-min-32-chars
AUTH_JWT_EXPIRES_IN=28800

# Google OAuth (Optional)
# NOTE: key names below MUST match what the code reads (google.strategy.ts):
#   GOOGLE_CALLBACK_URL  (not GOOGLE_REDIRECT_URI)
#   OAUTH_ALLOWED_DOMAIN (singular; not GOOGLE_ALLOWED_DOMAINS)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
OAUTH_ALLOWED_DOMAIN=carsu.edu.ph

# LDAP / Active Directory (Optional — institutional SSO)
# The LDAP strategy is registered ONLY when LDAP_URL is set (auth.module.ts). Leave blank to
# disable LDAP entirely and fall back to local + Google auth. Populate from MIS at go-live.
# LDAP_URL=ldaps://ldap.carsu.edu.ph:636
# LDAP_BIND_DN=cn=svc-pmo,ou=ServiceAccounts,dc=carsu,dc=edu,dc=ph
# LDAP_BIND_PASSWORD=change-me
# LDAP_SEARCH_BASE=ou=Users,dc=carsu,dc=edu,dc=ph
# LDAP_SEARCH_FILTER=(mail={{username}})
# LDAP_TLS_REJECT_UNAUTHORIZED=true

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv
