# PMO Backend Environment Configuration
# Copy this file to .env and update ALL values marked CHANGE_BEFORE_DEPLOY.
# Never commit the real .env file to version control.

# Database Connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=pmo_dashboard
DATABASE_USER=postgres
# Must match POSTGRES_PASSWORD in the root .env
DATABASE_PASSWORD=CHANGE_BEFORE_DEPLOY

# Application
PORT=3000
NODE_ENV=development

# Authentication (JWT)
# REQUIRED — generate a strong secret before any deployment:
#   openssl rand -base64 48
# Using the placeholder below in production makes all tokens forgeable.
AUTH_JWT_SECRET=CHANGE_BEFORE_DEPLOY
AUTH_JWT_EXPIRES_IN=28800

# Frontend URL — used for CORS origin restriction and Google OAuth redirect.
# In dev this can remain http://localhost:3001.
# In production set this to the URL end users navigate to (e.g. http://core.carsu.edu.ph).
FRONTEND_URL=http://localhost:3001

# Google OAuth (Optional — leave blank to disable Google login)
# NOTE: env var names must match exactly (google.strategy.ts reads these names):
#   GOOGLE_CALLBACK_URL  (not GOOGLE_REDIRECT_URI)
#   OAUTH_ALLOWED_DOMAIN (not GOOGLE_ALLOWED_DOMAINS)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
OAUTH_ALLOWED_DOMAIN=carsu.edu.ph

# LDAP / Active Directory (Optional — institutional SSO)
# The LDAP strategy is registered ONLY when LDAP_URL is set (auth.module.ts).
# Leave all LDAP_* lines commented out to disable LDAP entirely.
# Populate from MIS at go-live. See ldap-test/MIS_SWAP.md for the swap procedure.
# LDAP_URL=ldaps://ldap.carsu.edu.ph:636
# LDAP_BIND_DN=cn=svc-pmo,ou=ServiceAccounts,dc=carsu,dc=edu,dc=ph
# LDAP_BIND_PASSWORD=CHANGE_BEFORE_DEPLOY
# LDAP_SEARCH_BASE=ou=Users,dc=carsu,dc=edu,dc=ph
# LDAP_SEARCH_FILTER=(mail={{username}})
# LDAP_TLS_REJECT_UNAUTHORIZED=true

# Fresh-database SuperAdmin seed (Docker first-deploy only)
# seed.js runs ONLY when migrate.js detects an empty database.
# Has NO effect on an existing database — changing these after first deploy does nothing.
# CHANGE BOTH before any user accesses the system.
# Generate: openssl rand -base64 16
SEED_PMOADMIN_PASSWORD=CHANGE_BEFORE_DEPLOY
SEED_ADMIN_PASSWORD=CHANGE_BEFORE_DEPLOY

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv
