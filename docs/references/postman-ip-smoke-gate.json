                  "pm.test('IP-V4: Phase IN CTE fix active — at least one pillar has non-zero accomplishment_rate_pct', () => pm.expect(hasData, 'all pillars showing 0/null means Phase IN fix did NOT take effect — rebuild + restart backend').to.be.true);"
                ]
