              "query": [
                { "key": "fiscal_year", "value": "{{fiscal_year}}" },
                { "key": "quarter", "value": "Q1" }
              ]
            },
            "description": "Skip 14-B/14-C if qr_id is empty (no Q1 report exists yet). Not a hard gate failure — just means workflow cannot be tested in this run."
          },
          "response": []
        },
        {
          "name": "14-B: GET Quarterly Report by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('qr_id')) { pm.test('14-B skipped (no qr_id)', () => pm.expect.fail('Skipped — 14-A found no Q1 report')); return; }",
                  "pm.test('IP-V7a: 14-B status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('IP-V7a: publication_status is a valid enum value', () => pm.expect(['DRAFT','PENDING_REVIEW','PUBLISHED','REJECTED','UNLOCKED','REVERTED']).to.include(body.publication_status));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }],
            "url": {
              "raw": "{{base_url}}/api/university-operations/quarterly-reports/{{qr_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "university-operations", "quarterly-reports", "{{qr_id}}"]
            }
