# Root Docker Compose environment template.
# Copy to ".env" (same directory as docker-compose.yml) and fill in real values.
# Keep POSTGRES_* in sync with the DATABASE_* values in pmo-backend/.env.

POSTGRES_DB=pmo_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BACKEND_PORT=3000
FRONTEND_PORT=3001
