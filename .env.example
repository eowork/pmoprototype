# Root Docker Compose environment template.
# Copy to ".env" (same directory as docker-compose.yml) and update ALL values
# marked CHANGE_BEFORE_DEPLOY before running docker compose up.
# Never commit the real .env file to version control.
# Keep POSTGRES_* in sync with the DATABASE_* values in pmo-backend/.env.

POSTGRES_DB=pmo_dashboard
POSTGRES_USER=postgres
# REQUIRED — set a strong password before any deployment.
# Generate: openssl rand -base64 16
# Using a weak or default password with an exposed port is a critical security risk.
POSTGRES_PASSWORD=CHANGE_BEFORE_DEPLOY

POSTGRES_PORT=5432
BACKEND_PORT=3000
FRONTEND_PORT=3001
